def calculate_task_score(task) -> int:
    """
    Calculates a dynamic importance metric score for a given task entity.

    This function evaluates a task across five distinct layers—base priority tiers, 
    due date proximity, completion or review statuses, critical semantic tags, and 
    recent update windows—to output a scalar integer score used for queue sorting.

    Parameters
    ----------
    task : Task
        The task instance data object containing attributes for priority, due_date, 
        status, tags, and update timestamps.

    Returns
    -------
    int
        The computed total importance score. Note that this value can be negative 
        for low-priority tasks that are completed or in review.
    """
    # 1. Map base categorical priority enum onto static base weight scales
    priority_weights = {
        TaskPriority.LOW: 1,
        TaskPriority.MEDIUM: 2,
        TaskPriority.HIGH: 4,
        TaskPriority.URGENT: 6
    }
    score = priority_weights.get(task.priority, 0) * 10

    # 2. Add time-critical factors if a deadline milestone is active
    if task.due_date:
        days_until_due = (task.due_date - datetime.now()).days
        if days_until_due < 0:
            score += 35  # Overdue urgency escalation
        elif days_until_due == 0:
            score += 20  # Due today milestone
        elif days_until_due <= 2:
            score += 15  # Near-term window
        elif days_until_due <= 7:
            score += 10  # Standard weekly look-ahead

    # 3. Suppress visibility scores for tasks tracking towards resolution
    if task.status == TaskStatus.DONE:
        score -= 50  # Aggressive reduction for resolved items
    elif task.status == TaskStatus.REVIEW:
        score -= 15  # Moderate reduction for pending validation

    # 4. Search metadata array for critical operational tags
    if any(tag in ["blocker", "critical", "urgent"] for tag in task.tags):
        score += 8  # Global workflow bottleneck mitigation

    # 5. Incentivize high-activity focus via recency tracking
    days_since_update = (datetime.now() - task.updated_at).days
    if days_since_update < 1:
        score += 5  # Hot-task activity amplification

    return score
